# ATC System — Backend Environment Configuration
# Copy this to .env and update values

APP_NAME=ATC System
DEBUG=false
SECRET_KEY=change-this-secret-key-in-production

DB_HOST=mysql
DB_PORT=3306
DB_USER=atc_user
DB_PASSWORD=atc_password
DB_NAME=atc_db

CORS_ORIGINS=["http://localhost:3000","http://frontend:3000"]

UPLOAD_DIR=uploads
MODEL_DIR=ml/models
CLASSIFIER_MODEL_PATH=ml/models/classifier.pt
YOLO_MODEL_PATH=ml/models/yolov8n.pt

TRAIN_EPOCHS=30
TRAIN_BATCH_SIZE=16
IMAGE_SIZE=224
